# signposter Environment Configuration
# Copy this file to .env and fill in the values

# === Core Settings ===
SIGNPOSTER_ENV=development
SIGNPOSTER_LOG_LEVEL=INFO

# === Example placeholders (expand when needed) ===
# DATABASE_URL=postgresql://user:pass@localhost:5432/signposter
# REDIS_URL=redis://localhost:6379/0
# API_KEY=your-api-key-here

# === Feature Flags (optional) ===
# ENABLE_TELEMETRY=false